# pov.et — environment template.
#
# Copy to `.env` (gitignored). All variables are optional in dev: when
# DATABASE_URL is unset, the site falls back to lib/mock-data.json so a
# fresh clone still renders.

# ─── Database ────────────────────────────────────────────────────────────────
#
# Production: Neon Postgres (pooled DATABASE_URL + non-pooled DIRECT_URL).
# Local dev: point at Docker Postgres (see docker-compose.yml) or a Neon
# dev branch.
#
# Local Docker quickstart (port 5434 avoids collisions with 5432/5433):
#   DATABASE_URL="postgresql://povet:povet@localhost:5434/povet?schema=public"
#   DIRECT_URL="postgresql://povet:povet@localhost:5434/povet?schema=public"
#
# Neon scale-to-zero: lib/db.ts appends connect_timeout=30 automatically when
# missing. No need to add it here unless you want a different value.
DATABASE_URL=

# Direct (non-pooled) connection. Prisma Migrate needs this when DATABASE_URL
# is a pooler. For local Docker, set it to the same value as DATABASE_URL.
DIRECT_URL=

# ─── Image storage ───────────────────────────────────────────────────────────
#
# Production: Cloudflare R2 at media.pov.et (all five variables required).
# Local dev without R2: sync writes to public/media/ (gitignored).
#
# Setup:
#   1. Create an R2 bucket in your Cloudflare dashboard (e.g. `pov-et-media`).
#   2. In the bucket settings → "Settings" → "Public access":
#      a) For quick dev: enable the `r2.dev` subdomain. You'll get a URL
#         like `https://pub-<hash>.r2.dev`. Rate-limited; not for prod.
#      b) For production: bind a custom domain (e.g. `media.pov.et`) and
#         set R2_PUBLIC_URL to that.
#   3. R2 → "Manage R2 API Tokens" → create a token scoped to the bucket
#      with read+write. Copy the Access Key ID + Secret Access Key.
#   4. R2_ACCOUNT_ID is your Cloudflare account ID (top-right of the
#      Cloudflare dashboard, or visible in any R2 URL).
#   5. Fill in the values below, then re-run `pnpm run telegram:sync --
#      --full --limit 1000` to migrate existing posts to R2. The sync is
#      idempotent — running it overwrites Media rows in the database with
#      R2-backed URLs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ─── Telegram sync ───────────────────────────────────────────────────────────
#
# Telegram client API credentials.
#
#   1. Get TELEGRAM_API_ID + TELEGRAM_API_HASH from https://my.telegram.org
#      → API Development Tools. Use a personal Telegram account; the bot API
#      can't reliably read channel history.
#   2. Fill in API_ID + API_HASH below.
#   3. Run `pnpm run telegram:login` once. It will prompt for your phone
#      number, the Telegram code, and (if you have one) a 2FA password,
#      then print a session string.
#   4. Paste the session string into TELEGRAM_SESSION below. Keep it secret
#      — anyone with this string can act as your Telegram account.
#   5. Run `pnpm run telegram:sync` to pull the channel into Postgres.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=
TELEGRAM_CHANNEL=pov_et
